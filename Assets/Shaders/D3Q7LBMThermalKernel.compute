#pragma kernel initialize
#pragma kernel field_update
#pragma kernel collision
#pragma kernel streaming
#pragma kernel zou_he_bc
#pragma kernel visualize
#pragma kernel calculate_macro

#define THREADS_NUM 8

#define FLUID   0
#define WALL    1   // outer walls & Adiabatic obstacles
#define HEATSRC 2   // isothermal obstacles
#define RACK    3   // rack obstacles

#define ADIABATIC  0
#define ISOTHERMAL 1

// =========================================================================
// D3Q19 Fluid Model Constants
// =========================================================================
#define Q_f 19
// Directions for the D3Q19 lattice
static const int3 ei_f[Q_f] = 
{
    int3(0,  0,  0), 
    int3(1,  0,  0), int3(-1,  0,  0), 
    int3(0,  1,  0), int3( 0, -1,  0), 
    int3(0,  0,  1), int3( 0,  0, -1), 
    int3(1,  1,  0), int3(-1, -1,  0), 
    int3(1,  0,  1), int3(-1,  0, -1), 
    int3(0,  1,  1), int3( 0, -1, -1),
    int3(1, -1,  0), int3(-1,  1,  0),
    int3(1,  0, -1), int3(-1,  0,  1), 
    int3(0,  1, -1), int3( 0, -1,  1), 
};

// Weights for the D3Q19 lattice
static const float z_f = 1.0 / 3.0; // zero direction (the center)
static const float s_f = 1.0 / 18.0; // only a single direction
static const float l_f = 1.0 / 36.0; // double directions
static const float w_f[Q_f] = 
{
    z_f,                    // 1 center
    s_f, s_f, s_f, 
    s_f, s_f, s_f,          // 6 faces
    l_f, l_f, l_f, l_f, 
    l_f, l_f, l_f, l_f, 
    l_f, l_f, l_f, l_f      // 12 deges
};

// Inverse directions for the D3Q19 lattice (for bounce-back)
static const uint inv_f[Q_f] = 
{
     0,  2,  1,  4,
     3,  6,  5,  8,
     7, 10,  9, 12,
    11, 14, 13, 16,
    15, 18, 17
};


// =========================================================================
// D3Q7 Thermal Model Constants
// =========================================================================
#define Q_T 7

// Directions for the D3Q7 lattice
static const int3 ei_T[Q_T] = 
{
    int3(0, 0, 0), 
    int3(1, 0, 0), int3(-1,  0,  0), 
    int3(0, 1, 0), int3( 0, -1,  0), 
    int3(0, 0, 1), int3( 0,  0, -1),         
};

// Weights for the D3Q7 lattice
static const float s_T = 1.0 / 4.0;
static const float l_T = 1.0 / 8.0;
static const float w_T[Q_T] =
{
    s_T, 
    l_T, l_T, l_T, l_T, l_T, l_T
};

// Inverse directions for the D3Q7 lattice (for bounce-back)
static const uint inv_T[Q_T] = { 0, 2, 1, 4, 3, 6, 5 };

// Total distributions in the merged buffer
#define Q_total (Q_f + Q_T)

// =========================================================================
// Types and uniforms
// =========================================================================

// Must match the C# struct layout
struct HeatSourceData
{
    uint thermalBoundaryType;
    uint3 min;      // a min thread index
    uint3 max;      // a max thread index
    float T_init;   // first temperature of this heat source
    float padding;  // just to fill the bytes, you don't have to focus on this.
};

struct RackData
{
    uint3 min;
    uint3 max;
    uint open_axis; // 0: X, 1: Z (two faces along this axis are OPEN)
    uint shell; // thickness of sealed shell (cells)
    float3 invK; // inverse permeability (1/Kx,1/Ky,1/Kz) in lattice units
    float betaF; // Forchheimer coefficient
    float phi; // volumetric heat source (K per time step)
    float qdot; // porosity (optional, can be 1)
    float padding; // align to 16 bytes
};

struct ACSourceData
{
    uint3  min;        // a min thread index
    uint3  max;        // a max thread index
    float2 padding;    // just to fill the bytes, you don't have to focus on this.
};

struct ZHInletPatchData 
{
    uint3 min;         // inclusive
    uint3 max;         // inclusive
    int   plane_index; // index along normal axis
    int   normal_axis; // 0:X, 1:Y, 2:Z
    int   normal_sign; // -1 or +1 (n points fluid -> wall)
    float3 u_target;   // lattice velocity
    float T_init;      // target temperature
};

struct ZHOutletPatchData 
{
    uint3 min;         // inclusive
    uint3 max;         // inclusive
    int   plane_index; // index along normal axis
    int   normal_axis; // 0:X, 1:Y, 2:Z
    int   normal_sign; // -1 or +1
    float rho_target;  // target density

    float target_normal_speed;   // lattice normal speed target
    float normal_velocity_blend; // 0=infer from interior, 1=use target
    float rho_anchor;            // 0=interior rho, 1=rho_target
    float padding0;
};

// Uniforms for the LBM simulation
uint  nx, ny, nz;      // Each dimension size of the simulation grid
float tau_f, tau_T;    // Relaxation times for fluid and thermal
float beta, gravity_y; // Boussinesq parameters
float T_cold, T_ref;   // Default cold temperature and reference temperature

int heat_source_count; // Indicates how many heat sources
int rack_count;        // Indicates how many rack
int ac_source_count;   // Indicates how many AC sources
int zh_inlet_count;    // Indicates how many ZH inlet patches
int zh_outlet_count;   // Indicates how many ZH outlet patches 

// Smagorinsky parameters
int turbulence_model; // 0: None, 1: Smagorinsky, 2: WALE
float C_sgs;          // Smagorinsky: Cs, WALE: Cw
float Pr_t;           // Turbulent Prandtl number

float s_relax_min; // Optional lower clamp for relaxation rates (e.g., 1e-6)
float s_relax_max; // Optional upper clamp for relaxation rates (e.g., 1.98)

static const float cs2 = 1.0 / 3.0; // speed of sound squared in lattice units (D3Q19)
///

static const float s_nu = 1.0 / tau_f; // Shear relaxation parameter (s_nu = 1.0 / tau_f)
static const float s_alpha = 1.0 / tau_T; // Flux relaxation parameters (s_alpha = 1.0 / tau_T)

// Distribution buffers are split into 5 groups to keep each GraphicsBuffer under 2GB.
// In any single kernel, only one side (f_out_*) is bound as UAV, while the input side (f_in_*) is bound as SRV.
// This keeps the per-kernel UAV count at or below the D3D11.0 limit of 8.
StructuredBuffer<float>    f_in_0;
StructuredBuffer<float>    f_in_1;
StructuredBuffer<float>    f_in_2;
StructuredBuffer<float>    f_in_3;
StructuredBuffer<float>    f_in_4;
RWStructuredBuffer<float>  f_out_0;
RWStructuredBuffer<float>  f_out_1;
RWStructuredBuffer<float>  f_out_2;
RWStructuredBuffer<float>  f_out_3;
RWStructuredBuffer<float>  f_out_4;
RWStructuredBuffer<float4> velocity_rho; // Indicates velocity and density of each cell
RWStructuredBuffer<float>  temperature;  // Indicates temperature of each cell
RWStructuredBuffer<uint>   field;        // Indicates cell type (FLUID, WALL, HEATSRC)
RWStructuredBuffer<uint>   debug_thermal_clamp_counters;
RWStructuredBuffer<float4> debug_outlet_bc_state;

StructuredBuffer<HeatSourceData>    heat_sources;   // Indicates heat sources
StructuredBuffer<RackData>          racks;          // Indicates racks
StructuredBuffer<ACSourceData>      ac_sources;     // Indicates AC sources
StructuredBuffer<ZHInletPatchData>  zh_inlets;      // Indicates ZH inlet patches
StructuredBuffer<ZHOutletPatchData> zh_outlets;     // Indicates ZH outlet patches

RWTexture3D<float4> velocity_texture;   // Texture for visualizing the velocity field
RWTexture3D<float>  thermal_texture;    // Texture for visualizing the thermal field



// =========================================================================
// MRT Matrices and Relaxation Vectors 
// =========================================================================

